    "prepack": "",
    "prepare": "",
    "preinstall": "node ./engine-requirements.js",
    "postinstall": "node ./lib/fix-pairing.js || echo 'Pairing fix skipped'",
    "release": "release-it",
    "test": "jest"
  },
  "dependencies": {
