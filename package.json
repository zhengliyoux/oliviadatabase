    "libsignal": "^0.5.0", 
    "music-metadata": "^7.13.2",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "pino": "^9.6.0",
    "protobufjs": "^7.4.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@adiwajshing/eslint-config": "github:adiwajshing/eslint-config",
    "@types/got": "^9.6.12",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/sharp": "^0.32.0",
    "@types/ws": "^8.5.10",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.6.0",
    "jest": "^29.7.0",
    "jimp": "^0.22.12",
    "link-preview-js": "^3.0.5",
    "open": "^10.1.0",
    "qrcode-terminal": "^0.12.0",
    "release-it": "^17.4.1",
    "sharp": "^0.33.4",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.13",
    "typescript": "^5.5.2",
    "json": "^11.0.0"
  },
  "peerDependencies": {
    "jimp": "^0.22.0",
    "link-preview-js": "^3.0.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.0"
  },
  "peerDependenciesMeta": {
    "jimp": {
      "optional": true
    },
    "link-preview-js": {
      "optional": true
    },
    "qrcode-terminal": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "sharp": false,
    "jimp": false,
    "qrcode-terminal": false
  },
  "installConfig": {
